# Shared workspace environment template
# Copy to .env.development or .env.production and fill as needed.

# Runtime selector used by the backend dotenv loader.
KSUSER_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_DEBUG_STATE=dev
VITE_OAUTH_QQ_APPID=
VITE_OAUTH_GITHUB_CLIENT_ID=
VITE_OAUTH_GOOGLE_CLIENT_ID=
VITE_OAUTH_MICROSOFT_CLIENT_ID=
VITE_OAUTH_MICROSOFT_TENANT_ID=consumers

# Backend
DEBUG=true
DB_URL=jdbc:mysql://127.0.0.1:3306/ksuser?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_MASTER_KEY=replace-with-32-byte-base64-key
MAIL_HOST=smtp.exmail.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=consumers
APP_SSO_ISSUER=http://localhost:8000
APP_SSO_AUTHORIZATION_ENDPOINT=http://localhost:5173/sso/authorize
APP_OIDC_ISSUER=http://localhost:8000
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:5173
